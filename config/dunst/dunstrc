[urgency_low]
    background = "#121214"
    foreground = "#ffffff"
    timeout = 5
    # icon = /usr/share/icons/Adwaita/32x32/status/dialog-information-symbolic.symbolic.png

[urgency_normal]
    background = "#121214"
    foreground = "#ffffff"
    timeout = 5
    # icon = /usr/share/icons/Adwaita/32x32/status/dialog-question-symbolic.symbolic.png

[urgency_critical]
    background = "#121214"
    foreground = "#ffffff"
    frame_color = "#ff7f7f"
    timeout = 120
