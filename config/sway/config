# Specific window configuration
for_window    [app_id=".*"]                              sticky enable
for_window    [window_role="pop-up"]                     floating enable
for_window    [app_id="udiskie"]                         floating enable

# Default workspaces for common programs
assign [class="^Firefox$"] $ws1
assign [class="Slack"] $ws3
assign [app_id="telegramdesktop"] $ws3
assign [class="ticktick"] $ws5
for_window [class="Thunderbird"] move to workspace $ws5
for_window [class="Spotify"] move to workspace $ws6
exec slack
exec firefox
exec spotify
exec com.ticktick.TickTick
exec com.ulduzsoft.Birdtray
exec telegram-desktop

