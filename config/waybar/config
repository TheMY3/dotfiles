{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar at the bottom of your screen
    "height": 24, // Waybar height
    // "width": 1366, // Waybar width
    // Choose the order of the modules
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/scratchpad-indicator",
        "custom/spotify"
    ],
    // "modules-center": ["sway/window"],
    "modules-right": [
        "sway/language",
        "pulseaudio",
        "network",
        "backlight",
        "battery",
        "cpu",
        "memory",
        "tray",
        "idle_inhibitor",
        "custom/dunst",
        "clock"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{icon} {name}",
        // "format": "{name}: {icon}",
        "format-icons": {
            //"0: General": "´äæ",
            "1:web": "´ë¿", 
            "2:code": "´äí",
            "2:code": "´äí",
            "3:chat": "´ë║",
            "4:term": "´äá",
            "5:apps": "´Ç®",
            "6:music": "´ÇÑ",
            //"6:docs": "´£Ö",
            "urgent": "´ü¬",
            "focused": "´åÆ",
            "default": "´äæ",
            "persistent": "´Çù"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10,
        "show-passive-items" : false
    },
    "clock": {
        "timezone": "Europe/Kiev",
        "format": "´Çù {:%b %d %Y (%R)}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><span>{calendar}</span></tt>",
        "format-alt": "{:%Y-%m-%d}",
        "today-format": "<span color='#ff6699'><b><u>{}</u></b></span>",
        "calendar-weeks-pos": "left",
        "format-calendar": "<span color='#ecc6d9'><b>{}</b></span>",
        "format-calendar-weeks": "<span color='#99ffdd'><b>{}</b></span>",
        "format-calendar-weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "interval": 10
    },
    "cpu": {
        "format": "´ïø {usage}%"
    },
    "memory": {
        "format": "´âë {}%"
    },
    "battery": {
        "states": {
            "perfect": 100,
            "good": 95,
            "warning": 30,
            "critical": 10
        },
        "format": "{capacity}% {icon}",
        "format-charging": "´ùğ {capacity}%",
        "format-plugged": "´çĞ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-perfect": "",
        "format-good": "",
        // "format-full": "",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "network": {
        // "interface": "wlp2s0", // (Optional) To force the use of this interface
        "format-wifi": "´ç½ {essid}",
        "format-ethernet": "´âü {ifname}: {ipaddr}/{cidr}",
        "format-disconnected": "ÔÜá Disconnected",
        "tooltip-format": "´Şû {ifname} via {gwaddr}",
        "tooltip-format-wifi": "´ç½ {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "´âü {ifname}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "swaymsg exec '$term -e nmtui-connect'"
    },
    "pulseaudio": {
        //"scroll-step": 1,
        //"format": "{icon} {volume}%",
        //"format-bluetooth": "´èö {icon} {volume}%",

        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{icon}´èö {volume}% {format_source}",
        "format-bluetooth-muted": "´Ü® ´èö {volume}% {format_source}",
        "format-muted": "´Ü® {format_source}",
        "format-source": "´ä░",
        "format-source-muted": "´ä▒",


        "format-icons": {
            "headphones": "´ÇÑ",
            "handsfree": "´ûÉ",
            "headset": "´ûÉ",
            "phone": "´éò",
            "portable": "´éò",
            "car": "´å╣",
            "default": ["´Çğ", "´Ç¿"]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "on-click-middle": "pavucontrol",
        // "tooltip-format": "{desc}, {volume}%", // Uncomment for more info
        "tooltip": false
    },
    "custom/spotify": {
        "exec-if": "pgrep spotify",
        "exec": "/usr/bin/python3 $HOME/.config/waybar/modules/mediaplayer.py --player spotify",
        // "interval": 5, // Remove this if your script is endless and write in loop
        "format": "´å╝ {}",
        "max-length": 30,
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-click-right": "killall spotify"
        // "on-scroll-up": "playerctl next",
        // "on-scroll-down": "playerctl previous"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["´äæ", "´åà"],
        "on-scroll-up" : "light -A 5",
        "on-scroll-down" : "light -U 5"
    },
    "sway/language": {
        "format": "{short}",
        "tooltip": false
    },
    "custom/dunst": {
        "exec": "~/.config/waybar/modules/dunst.sh",
        "on-click": "dunstctl set-paused toggle",
        "restart-interval": 1,
        "tooltip": false
    },
    "idle_inhibitor": {
       "format": "{icon}",
       "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "custom/scratchpad-indicator": {
        "interval": 3,
        "return-type": "json",
        "exec": "swaymsg -t get_tree | jq --unbuffered --compact-output '(recurse(.nodes[]) | select(.name == \"__i3_scratch\") | .focus) as $scratch_ids | [..  | (.nodes? + .floating_nodes?) // empty | .[] | select(.id |IN($scratch_ids[]))] as $scratch_nodes | if ($scratch_nodes|length) > 0 then { text: \"\\($scratch_nodes | length)\", tooltip: $scratch_nodes | map(\"\\(.app_id // .window_properties.class) (\\(.id)): \\(.name)\") | join(\"\\n\") } else empty end'",
        "format": "´ïÆ {}",
        "on-click": "exec swaymsg 'scratchpad show'",
        "on-click-right": "exec swaymsg 'move scratchpad'"
    }
}
