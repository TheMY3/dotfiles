{
    "height": 30,
    "spacing": 4,
    "modules-left": [
        "sway/workspaces",
        "custom/scratchpad-indicator",
        "custom/spotify",
        "sway/mode"
    ],
    "modules-center": [
        "clock",
        "custom/weather",
        "custom/recorder"
    ],
    "modules-right": [
        "tray",
        "pulseaudio",
        "network",
        "backlight",
//        "cpu",
//        "memory",
//        "temperature",
        "custom/pacman",
        "idle_inhibitor",
        "custom/notification",
        "sway/language",
        "battery"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
         "format": "{icon} {name}",
        "format-icons": {
            "1:web": "",
            "2:code": "",
            "3:chat": "",
            "4:term": "",
            "5:apps": "",
            "6:music": "",
            "urgent": "",
            "focused": "",
            "default": "",
            "persistent": ""
        }
    },
    "sway/mode": {
        "format": "{}"
    },
    "custom/scratchpad-indicator": {
        "return-type": "json",
        "exec": "~/.config/waybar/modules/scratchpad-indicator.sh",
        "format": " {}",
        "on-click": "swaymsg 'scratchpad show'",
        "on-click-right": "swaymsg 'move scratchpad'"
    },
    "custom/spotify": {
        "exec-if": "pgrep spotify",
        "exec": "/usr/bin/python3 $HOME/.config/waybar/modules/mediaplayer.py --player spotify",
        "format": " {}",
        "max-length": 20,
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next"
    },
    "clock": {
        "timezone": "Europe/Kiev",
        "format": "{:%b %d %R}",
        "locale": "ru_RU.UTF-8",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><span>{calendar}</span></tt>",
        "format-alt": "{:%Y-%m-%d}",
        "today-format": "<span color='#ff6699'><b><u>{}</u></b></span>",
        "format-calendar": "<span color='#ecc6d9'><b>{}</b></span>",
        "format-calendar-weeks": "<span color='#99ffdd'><b>{}</b></span>",
        "format-calendar-weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "interval": 10
    },
    "custom/weather": {
        "icon-size": 42,
        "format": "{icon} {}",
        "tooltip": true,
        "interval": 3600,
        "exec": "~/.config/waybar/modules/weather.py",
        "return-type": "json",
        "format-icons": {
            "Unknown": "✨",
            "Cloudy": "",
            "Fog": "🌫",
            "HeavyRain": "🌧",
            "HeavyShowers": "🌧",
            "HeavySnow": "❄️",
            "HeavySnowShowers": "❄️",
            "LightRain": "🌦",
            "LightShowers": "🌦",
            "LightSleet": "🌧",
            "LightSleetShowers": "🌧",
            "LightSnow": "🌨",
            "LightSnowShowers": "🌨",
            "PartlyCloudy": "⛅️",
            "Sunny": "☀️",
            "ThunderyHeavyRain": "🌩",
            "ThunderyShowers": "⛈",
            "ThunderySnowShowers": "⛈",
            "VeryCloudy": ""
        }
    },
    "custom/recorder": {
        "format": "{}",
        "tooltip-format": "{tooltip}",
        "return-type": "json",
        "interval": 1,
        "exec": "echo '{\"class\": \"recording\",\"text\":\"\",\"tooltip\":\"press $mod+Esc to stop recording\"}'",
        "exec-if": "pgrep wf-recorder",
        "on-click": "swaymsg exec \\$recorder"
    },
    "tray": {
        "spacing": 10
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{icon} {volume}% {format_source}",
        "format-bluetooth-muted": "  {volume}% {format_source}",
        "format-muted": " {format_source}",
        "format-source": "",
        "format-source-muted": "",
        "format-icons": {
            "headphones": "",
            "handsfree": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", ""]
        },
        "on-click": "swaymsg exec \\$volume_mute",
        "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "on-click-middle": "pavucontrol",
        // "tooltip-format": "{desc}, {volume}%", // Uncomment for more info
        "tooltip": false
    },
    "network": {
        "format-wifi": "{essid} ",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ",
        "format-disconnected": "Disconnected ⚠",
        "format-alt": "{bandwidthUpBits}  {bandwidthDownBits}  ",
        "tooltip-format": "{ifname} via {gwaddr} ",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
        "tooltip-format-ethernet": "{ifname} ",
        "on-click-right": "swaymsg exec '$term_float -e nmtui-connect'"
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["", "", ""],
        "on-scroll-up" : "swaymsg exec \\$brightness_up",
        "on-scroll-down" : "swaymsg exec \\$brightness_down"
    },
    "cpu": {
        "format": "{usage}% ",
        "on-click": "swaymsg exec '$term_float -e htop"
    },
    "memory": {
        "format": "{}% ",
        "on-click": "swaymsg exec '$term_float -e htop'"
    },
     "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        // "critical-threshold": 80,
        // "format-critical": "{temperatureC}°C ",
        "format": "{temperatureC}°C "
    },
    "custom/pacman": {
        "format": "{} ",
        "interval": 3600,
        "exec": "~/.config/waybar/modules/pacman.sh",
        "exec-if": "exit 0",
        "return-type": "json",
        "tooltip": false,
        "on-click": "pamac-manager",
        "signal": 8
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        },
        "tooltip": false
    },
    "custom/dnd": {
        "format": "{}",
        "interval": 3600,
        "exec": "~/.config/waybar/modules/dnd.sh",
        "exec-if": "exit 0",
        "return-type": "json",
        "tooltip": false,
        "on-click": "dunstctl set-paused toggle",
        "signal": 8
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
          "notification": "<span foreground='red'><sup>\uF111</sup></span>",
          "none": "",
          "dnd-notification": "<span foreground='red'><sup>\uF111</sup></span>",
          "dnd-none": ""
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
      },
    "sway/language": {
        "format": "{shortDescription}",
        // https://github.com/swaywm/sway/issues/6011#issuecomment-812509175
        "on-click": "swaymsg -t get_inputs -r | jq '[.[] | select(.type == \"keyboard\") | .xkb_active_layout_index][0] - 1 | fabs' | xargs swaymsg 'input type:keyboard xkb_switch_layout'",
        "tooltip": false
    },
    "battery": {
        "states": {
            "full": 100,
            "good": 75,
            "warning": 30,
            "critical": 10
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        "format-alt": "{time} {icon}",
        "format-full": "",
        // "format-good": "",
        "format-icons": ["", "", "", "", ""]
    }
}
